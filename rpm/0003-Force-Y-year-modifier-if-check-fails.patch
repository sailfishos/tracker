From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Matti=20Lehtim=C3=A4ki?= <matti.lehtimaki@jolla.com>
Date: Fri, 23 Feb 2024 19:35:03 +0200
Subject: [PATCH] Force %Y year modifier if check fails

Updating glibc is needed to fix the year modifier check.
---
 meson.build | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/meson.build b/meson.build
index 05ff41125f8f76f104cafe54ed87f3b3be77b96b..99426260ea0b5a39ecd480bd90ae075ceeba3aa3 100644
--- a/meson.build
+++ b/meson.build
@@ -236,7 +236,8 @@ result = cc.run('''
   name: 'strftime 4-digit year modifier')
 
 if not result.compiled() or result.returncode() != 0
-  error('Libc implementation has broken 4-digit years implementation.')
+  warning('Libc implementation has broken 4-digit years implementation.')
+  year_modifier = '%Y'
 else
   year_modifier = result.stdout()
 endif
